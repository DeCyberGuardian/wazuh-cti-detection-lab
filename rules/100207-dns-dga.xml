<group name="cti,dns,sysmon,">

  <rule id="100207" level="8">
    <if_sid>100001</if_sid>
    <field name="win.system.eventID">^22$</field>

    <regex field="win.eventdata.queryName">^[a-z0-9]{20,}\.[a-z]{2,}$</regex>

    <description>Suspicious DNS query (DGA-like): $(win.eventdata.queryName) | proc=$(win.eventdata.image) | agent=$(agent.name)</description>

    <mitre>
      <id>T1568.002</id>
    </mitre>

    <group>dns,dga,suspicious,</group>
  </rule>

</group>